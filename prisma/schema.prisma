generator client {
  provider = "prisma-client"
  output   = "../lib/generated/client"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  WORKER
  ADMIN
}

enum InvoiceStatus {
  DRAFT
  SUBMITTED
  APPROVED
  PAID
  VOID
}

enum HourlyRateSource {
  TD_IMPORT
  MANUAL
}

enum PaymentType {
  TD_ONLY
  TD_PLUS
  MANUAL
}

enum TdFailureReason {
  UNMATCHED
  NEEDS_SETUP
  MISSING_RATE
}

enum PaymentAccountType {
  BANK_TRANSFER
  WISE
  PAYPAL
  CRYPTO
  REVOLUT
  OTHER
}

model User {
  id            String   @id @default(cuid())
  email         String   @unique
  name          String?
  role          Role     @default(WORKER)
  active        Boolean  @default(true)
  emailVerified Boolean  @default(false)
  image         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  sessions Session[]
  accounts Account[]
  worker   Worker?
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  expiresAt DateTime
  token     String   @unique
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Account {
  id                    String    @id @default(cuid())
  accountId             String
  userId                String
  providerId            String
  accessToken           String?
  refreshToken          String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  idToken               String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Worker {
  id                  String           @id @default(cuid())
  userId              String?          @unique
  name                String
  team                String?
  address             String?
  city                String?
  country             String?
  vatNumber           String?
  vatRate             Float            @default(0)
  paymentMethod       String?
  paymentAccount      String?
  paymentNotes        String?
  bankName            String?
  swiftCode           String?
  postCode            String?
  secondaryPayment    String?
  paymentType         PaymentType      @default(MANUAL)
  paymentConfigured   Boolean          @default(false)
  timeDoctorEmail     String?          @unique
  xeroContactId       String?
  hourlyRate          Float?
  hourlyRateSource    HourlyRateSource @default(TD_IMPORT)
  hourlyRateUpdatedAt DateTime?
  hourlyRateUpdatedBy String?
  currency            String?
  cryptoCoin          String?
  cryptoNetwork       String?
  cryptoWallet        String?
  paypalEmail         String?
  createdAt           DateTime         @default(now())
  updatedAt           DateTime         @updatedAt

  user            User?                @relation(fields: [userId], references: [id], onDelete: Cascade)
  invoices        Invoice[]
  paymentAccounts PaymentAccount[]
  rateConflicts   WorkerRateConflict[]
  matchFailures   TdMatchFailure[]
}

model PaymentAccount {
  id            String             @id @default(cuid())
  workerId      String
  type          PaymentAccountType
  label         String?
  isPreferred   Boolean            @default(false)
  accountNumber String?
  bankName      String?
  swiftCode     String?
  email         String?
  cryptoCoin    String?
  cryptoNetwork String?
  cryptoWallet  String?
  notes         String?
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt

  worker Worker @relation(fields: [workerId], references: [id], onDelete: Cascade)

  @@index([workerId])
  @@index([workerId, isPreferred])
}

model Invoice {
  id            String        @id @default(cuid())
  workerId      String
  tdSyncRunId   String?
  billingMonth  String?
  supplementNo  Int           @default(0)
  invoiceNumber String        @unique
  invoiceDate   DateTime
  dueDate       DateTime
  serviceDate   DateTime?
  status        InvoiceStatus @default(SUBMITTED)

  description String?
  period      String
  quantity    Float
  rate        Float

  // Amounts
  subtotal     Float
  vatAmount    Float
  totalAmount  Float
  vatRate      Float   @default(0)
  vatInclusive Boolean @default(false)
  currency     String  @default("EUR")

  // Xero Sync
  xeroSynced    Boolean   @default(false)
  xeroInvoiceId String?
  xeroSyncedAt  DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  worker    Worker        @relation(fields: [workerId], references: [id], onDelete: Cascade)
  tdSyncRun TdSyncRun?    @relation(fields: [tdSyncRunId], references: [id], onDelete: SetNull)
  lines     InvoiceLine[]

  @@unique([workerId, billingMonth, supplementNo])
  @@index([workerId])
  @@index([tdSyncRunId])
  @@index([status])
  @@index([invoiceDate])
}

model TimeDoctorConfig {
  id             String    @id @default("singleton")
  apiToken       String    @db.Text
  companyId      String
  tokenExpiresAt DateTime?
  lastSyncAt     DateTime?
  lastSyncStatus String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
}

model TdSyncRun {
  id              String           @id @default(cuid())
  runAt           DateTime         @default(now())
  billingMonth    String?
  status          String           @default("RUNNING")
  invoicesCreated Int              @default(0)
  skippedExisting Int              @default(0)
  matchFailed     Int              @default(0)
  inactiveSkipped Int              @default(0)
  ignoredSkipped  Int              @default(0)
  totalAmount     Float            @default(0)
  errorLog        String?          @db.Text
  triggeredBy     String?
  invoices        Invoice[]
  matchFailures   TdMatchFailure[]

  @@index([runAt])
}

model TdMatchFailure {
  id           String          @id @default(cuid())
  syncRunId    String
  tdUserId     String
  tdEmail      String
  tdName       String
  reason       TdFailureReason @default(UNMATCHED)
  workerId     String?
  billingMonth String?
  quantity     Float?
  resolved     Boolean         @default(false)
  resolvedAt   DateTime?
  syncRun      TdSyncRun       @relation(fields: [syncRunId], references: [id], onDelete: Cascade)
  worker       Worker?         @relation(fields: [workerId], references: [id], onDelete: SetNull)

  @@index([syncRunId])
  @@index([resolved])
  @@index([workerId])
}

// TD users who should never be treated as invoiceable workers (e.g. the company owner's own
// TD account — tracked in TD, but not someone who submits invoices). Checked before a sync run
// would otherwise create a fresh TdMatchFailure for them every single month.
model TdIgnoredEmail {
  id        String   @id @default(cuid())
  email     String   @unique
  reason    String?
  ignoredBy String
  createdAt DateTime @default(now())
}

model WorkerImportBatch {
  id            String               @id @default(cuid())
  importedBy    String
  importedAt    DateTime             @default(now())
  filename      String
  createdCount  Int                  @default(0)
  updatedCount  Int                  @default(0)
  conflictCount Int                  @default(0)
  rateConflicts WorkerRateConflict[]

  @@index([importedAt])
}

model WorkerRateConflict {
  id            String            @id @default(cuid())
  workerId      String
  portalRate    Float
  importedRate  Float
  importBatchId String
  resolved      Boolean           @default(false)
  resolvedAt    DateTime?
  resolvedBy    String?
  createdAt     DateTime          @default(now())
  worker        Worker            @relation(fields: [workerId], references: [id], onDelete: Cascade)
  importBatch   WorkerImportBatch @relation(fields: [importBatchId], references: [id], onDelete: Cascade)

  @@index([workerId])
  @@index([importBatchId])
  @@index([resolved])
}

model InvoiceLine {
  id          String   @id @default(cuid())
  invoiceId   String
  description String
  quantity    Float
  unitRate    Float
  amount      Float
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  invoice Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@index([invoiceId])
}

model InvoiceCounter {
  year  Int @id
  count Int @default(0)
}

model XeroToken {
  id           String   @id @default("singleton")
  accessToken  String   @db.Text
  refreshToken String   @db.Text
  tokenExpiry  DateTime
  tenantId     String
  updatedAt    DateTime @updatedAt
}

model WebhookConfig {
  id              String    @id @default(cuid())
  key             String
  environment     String    @default("production")
  url             String
  secret          String?
  internalSecret  String?
  enabled         Boolean   @default(true)
  lastTriggeredAt DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@unique([key, environment])
}
